					<Anchor point="TOPLEFT" x="10" y="-33"/>
				</Anchors>
				<Scripts>
					<OnValueChanged function="EzWoWRateSlider_OnValueChanged"/>
				</Scripts>
			</Slider>
			<EditBox name="$parentEdit" inherits="InputBoxTemplate">
				<Size x="50" y="18"/>
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="$parentSlider" relativePoint="TOPRIGHT" x="10"/>
				</Anchors>
				<Scripts>
					<OnLoad>self:SetAutoFocus(false)</OnLoad>
					<OnEscapePressed>self:ClearFocus()</OnEscapePressed>
					<OnEnterPressed>self:ClearFocus()</OnEnterPressed>
					<OnTextChanged function="EzWoWRateSlider_OnTextChanged"/>
					<OnEditFocusGained function="EzWoWRateSlider_OnEditFocusGained"/>
					<OnEditFocusLost function="EzWoWRateSlider_OnEditFocusLost"/>
				</Scripts>
			</EditBox>
			<Frame name="$parentDropDown" inherits="UIDropDownMenuTemplate" id="1">
				<Anchors>
					<Anchor point="TOPRIGHT" x="12" y="-3"/>
				</Anchors>
				<Scripts>
					<OnLoad>
						UIDropDownMenu_SetWidth(self, 110)
						UIDropDownMenu_Initialize(self, EzWoWRateDropDown_OnLoad)
						UIDropDownMenu_SetSelectedID(self, 1)
					</OnLoad>
					<OnShow>
						UIDropDownMenu_Initialize(self, EzWoWRateDropDown_OnLoad)
						UIDropDownMenu_Refresh(self, 1, 1)
					</OnShow>
				</Scripts>
			</Frame>
		</Frames>
	</Frame>

